@inherits LayoutComponentBase
@inject IJSRuntime JS

<PageTitle>RouterManagement</PageTitle>

<MudThemeProvider @bind-IsDarkMode="@_isDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h5" Class="ml-3">🌐 Router Hosts 🌐</MudText>
        <MudSpacer />
        <MudToggleIconButton @bind-Toggled="@_isDarkMode"
                             Icon="@Icons.Material.Filled.DarkMode" Color="Color.Inherit" title="Switch to Dark Mode"
                             ToggledIcon="@Icons.Material.Filled.LightMode" ToggledColor="Color.Inherit" />
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            <StatusBanner StatusMessage="@StatusMessage" />
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode;
    private bool _firstRender = true;
    private bool _previousDarkMode;

    private string StatusMessage { get; set; } = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _firstRender)
        {
            _firstRender = false;
            
            // Check if dark mode is already enabled in localStorage
            var theme = await JS.InvokeAsync<string>("localStorage.getItem", "theme");
            if (!string.IsNullOrEmpty(theme))
            {
                _isDarkMode = theme == "dark";
            }
            _previousDarkMode = _isDarkMode;
            StateHasChanged();
        }
        else if (!_firstRender && _previousDarkMode != _isDarkMode)
        {
            _previousDarkMode = _isDarkMode;
            await JS.InvokeVoidAsync("localStorage.setItem", "theme", _isDarkMode ? "dark" : "light");
        }
    }

    public void ShowStatusMessage(string message)
    {
        StatusMessage = message;
        InvokeAsync(StateHasChanged);
    }
}