@page "/"
@using RouterManagement.Data
@using RouterManagement.Data.Models
@using RouterManagement.Data.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject IHostManagementService hostManagementService
@inject NavigationManager NavigationManager
@implements IDisposable

@if (_hostData != null && _hostData.Success)
{
    <MudPaper Class="pa-4 mb-4" Elevation="1">
        <MudSwitch T="bool" Value="@_hostData.BlackListEnabled" ValueChanged="@((bool val) => ToggleBlackListStatus(val, _hostData))" Color="Color.Error" Label="Blacklist Status" />
    </MudPaper>

    <MudTable Items="@_hostData.HostList" Hover="true" Breakpoint="Breakpoint.Sm" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>Count</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<RouterHost, object>(x => x.Hostname)">Hostname</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<RouterHost, object>(x => x.IsOnline)">Online</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<RouterHost, object>(x => x.ConnectionType)">Type</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<RouterHost, object>(x => x.IsBlackListed)">Blacklisted</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<RouterHost, object>(x => x.IP)">IP</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<RouterHost, object>(x => x.Mac)">MAC</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<RouterHost, object>(x => x.Lease)">DHCP</MudTableSortLabel></MudTh>
            <MudTh>Packets Received</MudTh>
            <MudTh>Packets Sent</MudTh>
        </HeaderContent>
        <RowTemplate Context="host">
            @{
                var rowIndex = _hostData.HostList.IndexOf(host) + 1;
            }
            <MudTd DataLabel="Count">@rowIndex</MudTd>
            <MudTd DataLabel="Hostname">
                <TextEditor TModel="RouterHost" Model="host" CurrentValue="@host.Hostname" EditInitialValue="@host.Hostname" OnValueUpdated="HandleHostnameValueUpdated"></TextEditor>
            </MudTd>
            <MudTd DataLabel="Online">
                <MudIcon Icon="@(host.IsOnline ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(host.IsOnline ? Color.Success : Color.Error)" />
            </MudTd>
            <MudTd DataLabel="Type">@host.ConnectionType</MudTd>
            <MudTd DataLabel="Blacklisted">
                <MudCheckBox T="bool" Value="@host.IsBlackListed" ValueChanged="@((bool val) => ToggleBlacklist(val, host))" Color="Color.Error"></MudCheckBox>
            </MudTd>
            <MudTd DataLabel="IP">@host.IP</MudTd>
            <MudTd DataLabel="MAC">@host.Mac</MudTd>
            <MudTd DataLabel="DHCP">
                <TextEditor TModel="RouterHost" Model="host" CurrentValue="@host.Lease" EditInitialValue="@host.IP" OnValueUpdated="HandleDHCPValueUpdated"></TextEditor>
            </MudTd>
            <MudTd DataLabel="Packets Received">@host.PacketCountReceived</MudTd>
            <MudTd DataLabel="Packets Sent">@host.PacketCountSent</MudTd>
        </RowTemplate>
    </MudTable>
}
else
{
    if (_hostData == null)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else
    {
        <MudAlert Severity="Severity.Error">@_hostData.Error</MudAlert>
    }
}

@code {
    #region Fields
    private RouterHosts? _hostData;
    private HubConnection? _hubConnection;
    #endregion

    #region OnInitializedAsync
    protected override async Task OnInitializedAsync()
    {
        _hostData = await hostManagementService.GetDevicesAsync();
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hostUpdateHub"))
            .Build();

        _hubConnection.On<RouterHosts>("ReceiveHostUpdates", (updatedHostData) =>
        {
            _hostData = updatedHostData;
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
    }
    #endregion

    #region Dispose
    public void Dispose()
    {
        _ = _hubConnection?.StopAsync();
    }
    #endregion

    #region Blacklist Management
    protected async Task ToggleBlackListStatus(bool value, RouterHosts host)
    {
        host.BlackListEnabled = value;
        await hostManagementService.ToggleBlackListAsync(value);
    }

    private async Task ToggleBlacklist(bool value, RouterHost device)
    {
        device.IsBlackListed = value;
        if (value)
        {
            await hostManagementService.AddToBlackListAsync(device);
        }
        else
        {
            await hostManagementService.RemoveFromBlackListAsync(device);
        }

        StateHasChanged();
    }
    #endregion

    #region Hostname, DHCP Text
    private async void HandleHostnameValueUpdated(TextEditorUpdateModel<RouterHost> result)
    {
        await hostManagementService.SetHostnameAsync(result.NewValue, result.Model);
    }

    private void HandleDHCPValueUpdated(TextEditorUpdateModel<RouterHost> result)
    {
        Console.WriteLine($"Updated value:");
    }
    #endregion
}